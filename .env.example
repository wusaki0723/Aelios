CHATBOX_API_KEY=sk-chatbox-xxx
IM_API_KEY=sk-im-xxx
DEBUG_API_KEY=sk-debug-xxx
MEMORY_MCP_API_KEY=sk-memory-xxx

AI_GATEWAY_BASE_URL=https://gateway.ai.cloudflare.com/v1/<account>/<gateway>
CF_AIG_TOKEN=...

MEMORY_BACKEND=vectorize
VECTORIZE_INDEX_NAME=memo-kb
CLOUDFLARE_ACCOUNT_ID=...
CLOUDFLARE_API_TOKEN=...

MEMORY_FILTER_MODEL=openrouter/meta-llama/llama-3.3-70b-instruct
MEMORY_FILTER_MAX_CANDIDATES=12
MEMORY_FILTER_MAX_OUTPUT=6
MEMORY_FILTER_MAX_CONTENT_CHARS=700
# Recall floors on the raw embedding score, applied before the reranker.
# Low on purpose — embeddinggemma under-scores reworded-but-relevant hits;
# the reranker + compressor handle precision downstream.
MEMORY_FILTER_MIN_SCORE=0.1
MEMORY_MIN_SCORE=0.1
MEMORY_TOP_K=12
EMBEDDING_MODEL=google-ai-studio/gemini-embedding-2
EMBEDDING_DIMENSIONS=768

ANTHROPIC_CACHE_ENABLED=true
ANTHROPIC_AUTO_CACHE_ENABLED=true
ANTHROPIC_ROLLING_CACHE_ENABLED=true
ANTHROPIC_CACHE_TTL=5m
